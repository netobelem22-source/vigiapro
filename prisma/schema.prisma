generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Segmento {
  LOJA
  OBRA
  EXPANSAO
}

enum Role {
  VIGIA
  GERENTE
  GESTOR
  TERCEIRO
}

enum StatusPedido {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

enum StatusPonto {
  ABERTO
  CONFIRMADO
  FECHADO
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  role      Role
  fcmToken  String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  unidade   Unidade? @relation(fields: [unidadeId], references: [id])
  unidadeId String?

  pedidos      Pedido[]
  pontos       Ponto[]
  confirmacoes Ponto[] @relation("Confirmacoes")
  historicos   HistoricoPedido[]
  unidadesParceiras UnidadeParceiro[]

  @@index([unidadeId, role])
}

model Empresa {
  id       String    @id @default(uuid())
  nome     String
  cnpj     String?   @unique
  ativo    Boolean   @default(true)
  unidades Unidade[]
}

model Unidade {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?
  endereco  String
  cidade    String
  estado    String
  latitude  Float?
  longitude Float?
  raioGps      Int      @default(200)
  valorDiaria  Float?   // valor contratado por diária nesta unidade
  ativo        Boolean  @default(true)

  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  usuarios  Usuario[]
  pedidos   Pedido[]
  pontos    Ponto[]
  parceiros UnidadeParceiro[]
}

model Pedido {
  id               String       @id @default(uuid())
  data             DateTime
  turno            String
  qtdVigiaDia      Int          @default(0)
  qtdVigiNoite     Int          @default(0)
  inicioTurnoDia   String?
  inicioTurnoNoite String?
  fimTurnoDia      String?
  fimTurnoNoite    String?
  observacao       String?
  status           StatusPedido @default(PENDENTE)
  segmento         String       @default("LOJA")
  criadoEm         DateTime     @default(now())

  unidade       Unidade  @relation(fields: [unidadeId], references: [id])
  unidadeId     String

  solicitante   Usuario  @relation(fields: [solicitanteId], references: [id])
  solicitanteId String

  pontos        Ponto[]
  historico     HistoricoPedido[]
  links         LinkPonto[]

  @@index([unidadeId])
  @@index([data])
  @@index([status])
}

model Ponto {
  id              String      @id @default(uuid())
  tipo            String
  horario         DateTime
  fotoUrl         String?
  latitude        Float?
  longitude       Float?
  gpsValido       Boolean     @default(false)
  nomeVigia       String?
  manual          Boolean     @default(false)
  numeroVaga      Int?
  observacao      String?
  status          StatusPonto @default(ABERTO)
  confirmedAt     DateTime?
  criadoEm        DateTime    @default(now())

  vigia           Usuario? @relation(fields: [vigiaId], references: [id])
  vigiaId         String?

  unidade         Unidade  @relation(fields: [unidadeId], references: [id])
  unidadeId       String

  pedido          Pedido?  @relation(fields: [pedidoId], references: [id])
  pedidoId        String?

  confirmadoPor   Usuario? @relation("Confirmacoes", fields: [confirmadoPorId], references: [id])
  confirmadoPorId String?

  @@index([vigiaId])
  @@index([unidadeId])
  @@index([horario])
  @@index([status])
}

model Configuracao {
  id           String   @id @default(uuid())
  valorDiaria  Float    @default(180)
  atualizadoEm DateTime @updatedAt
}

model HistoricoPedido {
  id        String   @id @default(uuid())
  pedidoId  String
  usuarioId String
  acao      String   // "CRIADO" | "CONFIRMADO" | "CANCELADO"
  detalhe   String?
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
}

model LinkPonto {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  pedidoId  String
  vigiaId   String?
  tipo      String   // ENTRADA | SAIDA
  usado     Boolean  @default(false)
  numeroVaga   Int?     @default(1)
  totalVagas   Int?     @default(1)
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
}

// Vincula um usuário TERCEIRO às unidades que ele está autorizado a atender.
// Editável a qualquer momento pelo GESTOR, sem alterar código.
model UnidadeParceiro {
  id       String   @id @default(uuid())
  criadoEm DateTime @default(now())

  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  usuarioId String

  unidade   Unidade @relation(fields: [unidadeId], references: [id])
  unidadeId String

  @@unique([usuarioId, unidadeId])
  @@index([unidadeId])
}
